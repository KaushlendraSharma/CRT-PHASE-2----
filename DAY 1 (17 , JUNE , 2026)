[HASH MAP]

class Solution {
public:
    vector<int> twoSum(vector<int>& nums, int target) {
       int n = nums.size();
       map<int , int>m;
       for (int i = 0 ; i<n ;i++){
        int complement = target - nums[i];
        if (m.count(complement)){
            return {m[complement],i};
           
        }
         m[nums[i]] = i;
       }
       return{};
    }
    
};
