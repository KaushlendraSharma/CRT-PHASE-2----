    }

    void push(int x) {
        Node* t = new Node(x);
        t->next = head;
        // Adds an element x at the top of the stack
        head = t;
        c++;
        
    }

    void pop() {
        if(head==NULL) return;
        // Removes the top element of the stack
        head = head->next;
        c--;
    }

    int peek() {
        if(head==NULL) return -1;
        // Returns the top element of the stack
