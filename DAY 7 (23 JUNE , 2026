//--------------\\
   TWO POINTERS
\\--------------// 


class Solution {
public:
    ListNode *getIntersectionNode(ListNode *headA, ListNode *headB) {
ListNode* tA = headA;
        ListNode* tB = headB;

        while (tA!=tB){
            if(tA==NULL) tA = headB;
            else tA = tA->next;

            if(tB==NULL) tB = headA;
            else tB = tB->next;
        }

        return tA;
    }
};
