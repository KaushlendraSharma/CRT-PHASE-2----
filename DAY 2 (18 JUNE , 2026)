-------------------------------LC 860 - LEMONADE CHANGE---------------------------

class Solution {
public:
    bool lemonadeChange(vector<int>& bills) {
        int five = 0;
        int ten = 0;   
        for(int i :bills){
            if (i==5) five++;
            else if(i==10 && five>0){
                ten++;
                five--;
            }
            else if(i==20 && ten>0 && five >0){
                ten--;
                five--;
            }
            else if (i==20 && five>=3) five -=3;

            else return false;
        }
        return true;
    }
};
