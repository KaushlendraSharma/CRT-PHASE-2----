APPROACH 1 - 

class Solution {
public:
    void sortColors(vector<int>& nums) {
       int n = nums.size();
     
        int c0 = count(nums.begin(), nums.end(),0);
        int c1 = count(nums.begin(), nums.end(),1);
        int c2 = count(nums.begin(), nums.end(),2);

        vector<int>ans;

       for (int i = 0; i<c0 ; i++ ) ans.push_back(0);
       for (int i = 0; i<c1 ; i++ ) ans.push_back(1);
       for (int i = 0; i<c2 ; i++ ) ans.push_back(2);
       nums = ans;
    }
};
