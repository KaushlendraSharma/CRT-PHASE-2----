/**
 * Definition for singly-linked list.
 * struct ListNode {
 *     int val;
 *     ListNode *next;
 *     ListNode(int x) : val(x), next(NULL) {}
 * };
 */
class Solution {
public:
    ListNode *detectCycle(ListNode *head) {
        set <ListNode*>s;

        while (head!=NULL){
            if (s.count(head)) return head;

            s.insert(head);
            head = head->next;
        }
        return NULL;
    }
};



